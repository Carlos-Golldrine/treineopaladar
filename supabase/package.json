{
  "name": "treine-paladar-supabase",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "description": "Ferramental de migracao e seed do Supabase (aplica migrations/*.sql e importa o catalogo de vinhos).",
  "scripts": {
    "migrate": "node --env-file=.env migrate.mjs",
